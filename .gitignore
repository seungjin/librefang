*.pem
*.key
*.cert
*.p12
*.pfx
# AUR CI deploy key pair (OpenSSH key has no extension, so *.pem / *.key miss it).
# Lives at the repo root for local AUR publishing; never commit it.
/aur_ci
/aur_ci.pub

